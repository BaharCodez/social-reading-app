// Prisma schema — users/accounts/sessions are the Auth.js shape; Book and
// Annotation hold the shared reading data.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// --- Auth.js models ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Set only for email/password accounts; null for OAuth-only users.
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  books       Book[]
  annotations Annotation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Reading data --------------------------------------------------------

model Book {
  id           String   @id @default(cuid())
  title        String
  author       String
  coverDataUrl String?
  // The raw EPUB file. Fine in SQLite for now; revisit for large libraries.
  data         Bytes
  ownerId      String
  createdAt    DateTime @default(now())

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  annotations Annotation[]
}

model Annotation {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  cfiRange  String
  text      String
  comment   String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId])
}
