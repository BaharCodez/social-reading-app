// Prisma schema — users/accounts/sessions are the Auth.js shape; Book and
// Annotation hold the shared reading data.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js models ------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Set only for email/password accounts; null for OAuth-only users.
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  books       Book[]
  annotations Annotation[]
  progress    ReadingProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Reading data --------------------------------------------------------

model Book {
  id           String   @id @default(cuid())
  title        String
  author       String
  coverDataUrl String?
  // The raw EPUB file. Fine in SQLite for now; revisit for large libraries.
  data         Bytes
  ownerId      String
  createdAt    DateTime @default(now())

  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  annotations Annotation[]
  progress    ReadingProgress[]
}

model Annotation {
  id        String   @id @default(cuid())
  bookId    String
  userId    String
  cfiRange  String
  text      String
  comment   String
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

// --- Writing room ----------------------------------------------------------

// A blog post, written in markdown. Drafts have publishedAt = null and are
// only visible when signed in.
model Post {
  id          String    @id @default(cuid())
  title       String
  content     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// An image embedded in a post — stored the same way books are (bytes in
// the DB), served from /api/images/[id].
model Image {
  id        String   @id @default(cuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())
}

// A sticky note on the hobby board: something to read about, write about,
// explore, or solve.
model Idea {
  id        String   @id @default(cuid())
  bucket    String // "read" | "write" | "explore" | "solve"
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- Hallway -------------------------------------------------------------

// A frame hanging on the hallway wall: a job, a project, or any achievement
// worth showing off. Added/removed from the hallway page while signed in.
model Frame {
  id        String   @id @default(cuid())
  kind      String // "job" | "project" | "achievement"
  title     String
  subtitle  String   @default("")
  detail    String   @default("")
  years     String? // freeform: "2023–now", "summer 2024", …
  link      String?
  sort      Int      @default(0)
  createdAt DateTime @default(now())
}

// Per-user reading position in a book (synced across that user's devices).
model ReadingProgress {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  cfi       String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}
